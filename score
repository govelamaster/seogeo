                    name: 'Estructura Semántica',
                    max: 15,
                    score: Math.floor(Math.random() * 8) + 2, // 2-10 de 15
                },
                {
                    name: 'Señales Citabilidad',
                    max: 10,
                    score: Math.floor(Math.random() * 5), // 0-5 de 10
                }
            ];

            const totalScore = categories.reduce((sum, cat) => sum + cat.score, 0);

            // Issues por industria
            const industryIssues = {
                turismo: ['Falta schema LocalBusiness y TouristAttraction', 'Sin FAQ sobre destinos populares'],
                legal: ['No tienes schema LegalService', 'Contenido no responde preguntas legales comunes'],
                ecommerce: ['Schema Product incompleto', 'Reviews sin markup estructurado'],
                salud: ['Falta schema MedicalOrganization', 'Contenido sin credenciales E-E-A-T'],
                saas: ['No tienes schema SoftwareApplication', 'Casos de uso poco específicos'],
                'bienes-raices': ['Schema RealEstateAgent ausente', 'Listados sin geo-targeting'],
                construccion: ['Proyectos sin schema CreativeWork', 'Portfolio no optimizado para IAs'],
                educacion: ['Schema EducationalOrganization faltante', 'Cursos sin estructura Course'],
                financiero: ['Falta schema FinancialService', 'Sin menciones en Knowledge Graph'],
                otro: ['Schema Organization incompleto', 'Contenido genérico sin autoridad']
            };

            const issues = [
                {
                    title: 'Schema.org incompleto',
                    problems: [
                        industryIssues[industry]?.[0] || 'No tienes Organization schema completo',
                        'Falta FAQPage schema',
                        'Sin BreadcrumbList en navegación'
                    ],
                    tip: 'Las IAs usan Schema.org como mapa de lectura principal de tu contenido'
                },
                {
                    title: 'Contenido no optimizado para IAs',
                    problems: [
                        'Artículos sin respuestas directas en primeros párrafos',
                        'Párrafos >200 palabras (IAs prefieren <150)',
                        'Sin listas numeradas ni bullets',
                        industryIssues[industry]?.[1] || 'Contenido genérico sin diferenciadores'
                    ],
                    tip: 'ChatGPT y Perplexity necesitan formato escaneable y respuestas inmediatas'
                },
                {
                    title: 'CERO menciones de marca verificadas',
                    problems: [
                        'No apareces en Google Knowledge Graph',
                        'Sin entidad en Wikipedia o Wikidata',
                        'Redes sociales no conectadas vía sameAs',
                        'Sin menciones en medios reconocidos'
                    ],
                    tip: 'IAs buscan señales de autoridad externa antes de citarte como fuente confiable'
                }
            ];

            return {
                score: totalScore,
                categories,
                issues
            };
        };

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const urlRaw = document.getElementById('url').value;
            const industry = document.getElementById('industry').value;
            const email = document.getElementById('email').value;

            // Normalizar y validar URL
            const urlResult = normalizeURL(urlRaw);
            
            if (!urlResult.valid) {
                urlInput.classList.add('input-error');
                urlError.classList.add('active');
                urlError.textContent = 'Por favor ingresa un dominio válido (ej: ejemplo.com)';
                return;
            }

            const url = urlResult.normalized;

            // Ocultar form, mostrar loading
            formSection.style.display = 'none';
            loadingSection.classList.add('active');

            // Animar pasos de loading
            const steps = document.querySelectorAll('.loading-step');
            for (let i = 0; i < steps.length; i++) {
                await new Promise(resolve => setTimeout(resolve, 800));
                steps[i].classList.add('active');
            }

            await new Promise(resolve => setTimeout(resolve, 1500));

            // Analizar y mostrar resultados
            const results = analyzeWebsite(url, industry);

            // Ocultar loading, mostrar results
            loadingSection.classList.remove('active');
            resultsSection.classList.add('active');

            // Animar score
            const scoreNumber = document.getElementById('scoreNumber');
            const progressFill = document.getElementById('progressFill');
            const scoreStatus = document.getElementById('scoreStatus');

            let currentScore = 0;
            const targetScore = results.score;
            const increment = targetScore / 50;

            const scoreInterval = setInterval(() => {
                currentScore += increment;
                if (currentScore >= targetScore) {
                    currentScore = targetScore;
                    clearInterval(scoreInterval);
                }
                scoreNumber.textContent = Math.floor(currentScore) + '/100';
            }, 30);

            setTimeout(() => {
                progressFill.style.width = targetScore + '%';
            }, 100);

            // Status según score
            if (targetScore < 40) {
                scoreStatus.className = 'score-status critical';
                scoreStatus.innerHTML = `
                    <div style="font-size: 18px; margin-bottom: 8px;">🔴 PREPARACIÓN CRÍTICA</div>
                    <div>Tu sitio NO está listo para citaciones en IAs. Riesgo: tus competidores pueden estar siendo recomendados mientras tú permaneces invisible.</div>
                `;
            } else if (targetScore < 70) {
                scoreStatus.className = 'score-status medium';
                scoreStatus.innerHTML = `
                    <div style="font-size: 18px; margin-bottom: 8px;">🟡 PREPARACIÓN MEDIA</div>
                    <div>Tienes bases pero necesitas optimización urgente para competir en el ecosistema GEO.</div>
                `;
            } else {
                scoreStatus.className = 'score-status good';
                scoreStatus.innerHTML = `
                    <div style="font-size: 18px; margin-bottom: 8px;">🟢 BUENA PREPARACIÓN</div>
                    <div>Vas por buen camino. Con ajustes estratégicos puedes dominar tu nicho en IAs.</div>
                `;
            }

            // Breakdown categorías
            const categoriesDiv = document.getElementById('categoriesBreakdown');
            categoriesDiv.innerHTML = results.categories.map(cat => `
                <div class="category">
                    <div class="category-header">
                        <span class="category-name">${cat.name}</span>
                        <span class="category-score">${cat.score}/${cat.max}</span>
                    </div>
                    <div class="category-bar">
                        <div class="category-fill" style="width: ${(cat.score / cat.max * 100)}%"></div>
                    </div>
                </div>
            `).join('');

            // Issues
            const issuesDiv = document.getElementById('issuesList');
            issuesDiv.innerHTML = results.issues.map(issue => `
                <div class="issue-item">
                    <div class="issue-title">${issue.title}</div>
                    <ul class="issue-problems">
                        ${issue.problems.map(p => `<li>${p}</li>`).join('')}
                    </ul>
                    <div class="issue-tip">${issue.tip}</div>
                </div>
            `).join('');

            // Industry name
            const industryNames = {
                turismo: 'turismo y hospitalidad',
                legal: 'servicios legales',
                ecommerce: 'ecommerce',
                salud: 'salud y wellness',
                saas: 'tecnología B2B',
                'bienes-raices': 'bienes raíces',
                construccion: 'construcción',
                educacion: 'educación',
                financiero: 'servicios financieros',
                otro: 'tu industria'
            };
            document.getElementById('industryName').textContent = industryNames[industry] || industry;

            // Scroll suave a resultados
            setTimeout(() => {
                resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 500);

            // Enviar lead a backend (aquí puedes integrar Zapier, Make, email API, etc)
            console.log('Lead capturado:', { url, industry, email, score: targetScore });
        });
    </script>
</body>
