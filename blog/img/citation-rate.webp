    align-items: center;
    justify-content: center;
    font-size: 34px;
    box-shadow: 0 16px 36px rgba(108,76,255,.10);
  }

  .shift-label {
    width: fit-content;
    margin-bottom: 18px;
    padding: 8px 18px;
    border-radius: 999px;
    background: #f2edff;
