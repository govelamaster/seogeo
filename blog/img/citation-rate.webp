    font-size: 17px;
    line-height: 1.58;
    color: #5b6072;
  }

  .shift-card small {
    display: inline-flex;
    margin-top: 28px;
    padding: 8px 16px;
    border-radius: 999px;
    background: #f7f3ff;
    color: #4a2da8;
    font-size: 13px;
    font-weight: 700;
  }

  .shift-arrow {
    width: 46px;
    height: 46px;
    margin: 0 auto;
    border-radius: 999px;
    background: rgba(255,255,255,.9);
    border: 1px solid #ece8fb;
    box-shadow: 0 14px 34px rgba(50,40,110,.08);
