  }

  .shift-intro {
    max-width: 780px;
    margin: 28px auto 52px;
    font-size: 20px;
    line-height: 1.55;
    color: #5b6072;
  }

  .shift-grid {
    display: grid;
    grid-template-columns: 1fr 56px 1fr 56px 1fr;
    align-items: center;
    gap: 0;
  }

  .shift-card {
    min-height: 330px;
    padding: 42px 38px 34px;
    border-radius: 28px;
    background: rgba(255,255,255,.86);
    border: 1px solid #ece8fb;
    box-shadow: 0 24px 68px rgba(50,40,110,.08);
    text-align: left;
  }

  .shift-icon {
    width: 70px;
    height: 70px;
    margin-bottom: 30px;
    border-radius: 50%;
    background: linear-gradient(180deg, #f4efff 0%, #ffffff 100%);
