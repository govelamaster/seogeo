<style>
  .geo-score-banner {
    width: 100%;
    padding: 30px 16px;
    background: #ffffff;
  }

  .geo-score-banner-inner {
    max-width: 1180px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    padding: 34px 24px;
    background:
      radial-gradient(circle at 75% 55%, rgba(124, 92, 255, 0.35), transparent 34%),
      radial-gradient(circle at 20% 15%, rgba(168, 85, 247, 0.18), transparent 28%),
      linear-gradient(135deg, #08091f 0%, #181044 48%, #2e176c 100%);
    color: #ffffff;
    box-shadow:
      0 30px 90px rgba(32, 24, 80, 0.22),
      inset 0 1px 0 rgba(255,255,255,0.16);
    display: grid;
    grid-template-columns: 1fr;
    gap: 34px;
  }

  .geo-score-banner-inner::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(circle at 70% 50%, black, transparent 70%);
    pointer-events: none;
  }

  .geo-score-copy,
  .geo-score-visual {
    position: relative;
    z-index: 2;
  }

  .geo-score-pill {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.16);
    color: rgba(255,255,255,0.86);
    font-size: 11px;
    font-weight: 850;
    letter-spacing: 0.06em;
    margin-bottom: 22px;
  }

  .geo-score-copy h2 {
    margin: 0;
    font-size: clamp(42px, 11vw, 82px);
    line-height: 0.9;
    letter-spacing: -0.07em;
    font-weight: 900;
  }

  .geo-score-copy h2 span {
    display: block;
    background: linear-gradient(135deg, #7c5cff, #f472ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .geo-score-copy p {
    margin: 22px 0 0;
    max-width: 540px;
    color: rgba(255,255,255,0.78);
    font-size: clamp(17px, 4vw, 23px);
    line-height: 1.45;
  }

  .geo-score-copy p strong {
    color: #a78bff;
  }

  .geo-score-btn {
    margin-top: 28px;
    min-height: 64px;
    width: 100%;
    max-width: 520px;
    border-radius: 20px;
    background: linear-gradient(135deg, #8b5cf6 0%, #5f35ff 100%);
    color: #ffffff;
    text-decoration: none;
    display: grid;
    grid-template-columns: 50px 1fr 34px;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    font-size: clamp(17px, 4vw, 26px);
    font-weight: 900;
    box-shadow:
      0 24px 60px rgba(95, 53, 255, 0.45),
      0 0 34px rgba(124, 92, 255, 0.34),
      inset 0 1px 0 rgba(255,255,255,0.22);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
  }

  .geo-score-btn span {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(255,255,255,0.14);
    display: grid;
    place-items: center;
  }

  .geo-score-btn b {
    font-size: 34px;
    line-height: 1;
  }

  .geo-score-btn:hover {
    transform: translateY(-4px);
    filter: brightness(1.06);
    box-shadow:
      0 34px 80px rgba(95, 53, 255, 0.56),
      0 0 52px rgba(168, 85, 247, 0.50);
  }

  .geo-score-trust {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 22px;
    color: rgba(255,255,255,0.82);
    font-size: 14px;
    font-weight: 750;
  }

  /* VISUAL */
  .geo-score-visual {
    min-height: 300px;
    display: grid;
    place-items: center;
  }

  .score-card {
    width: min(100%, 420px);
    padding: 28px;
    border-radius: 28px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(20px);
    box-shadow:
      0 28px 80px rgba(0,0,0,0.28),
      0 0 60px rgba(124,92,255,0.28),
      inset 0 1px 0 rgba(255,255,255,0.18);
    transform: rotate(0deg);
  }

  .score-card > p {
    margin: 0 0 18px;
    color: rgba(255,255,255,0.76);
    font-size: 16px;
    font-weight: 800;
  }

  .score-circle {
    width: 210px;
    height: 115px;
    margin: 0 auto 14px;
    border-radius: 210px 210px 0 0;
    border-top: 18px solid #a78bff;
    border-left: 18px solid rgba(167,139,255,0.22);
    border-right: 18px solid #ffffff;
    display: grid;
    place-items: center;
  }

  .score-circle span {
    margin-top: 30px;
    color: #ffffff;
    font-size: 70px;
    line-height: 0.8;
    font-weight: 900;
    letter-spacing: -0.06em;
  }

  .score-circle small {
    margin-top: -20px;
    color: rgba(255,255,255,0.55);
    font-size: 20px;
    font-weight: 700;
  }

  .score-status {
    width: fit-content;
    margin: 0 auto 22px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(34,197,94,0.16);
    color: #57f287;
    font-size: 13px;
    font-weight: 900;
  }

  .score-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 18px;
  }

  .score-metrics div {
    text-align: center;
  }

  .score-metrics small {
    display: block;
    color: rgba(255,255,255,0.58);
    font-size: 11px;
    margin-bottom: 6px;
  }

  .score-metrics strong {
    color: #ffffff;
    font-size: 22px;
    font-weight: 900;
  }

  .score-badge {
    position: absolute;
    top: 0;
    right: 0;
    width: 104px;
    height: 104px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 20%, #ecff75, #b8ff68);
    color: #08091f;
    display: grid;
    place-items: center;
    text-align: center;
    font-size: 12px;
    line-height: 1.05;
    font-weight: 900;
    box-shadow:
      0 16px 40px rgba(184,255,104,0.25),
      inset 0 0 0 5px rgba(255,255,255,0.80);
    z-index: 4;
  }

  .score-badge strong {
    font-size: 36px;
    line-height: 0.9;
  }

  @media (min-width: 860px) {
    .geo-score-banner {
      padding: 44px 28px;
    }

    .geo-score-banner-inner {
      grid-template-columns: 1fr 0.9fr;
      padding: 56px 64px;
      gap: 44px;
      align-items: center;
    }

    .score-card {
      transform: rotate(4deg);
    }

    .score-badge {
      top: 12px;
      right: 22px;
      width: 128px;
      height: 128px;
    }

    .score-badge strong {
      font-size: 46px;
    }
  }
</style>



