<style>
  .ai-shift-section {
    width: 100%;
    padding: 78px 20px 70px;
    background:
      radial-gradient(circle at 50% 100%, rgba(108,76,255,.12), transparent 34%),
      linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
