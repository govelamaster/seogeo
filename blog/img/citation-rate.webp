<style>
/* HERO */
.geo-hero{
  position:relative;
  padding:40px 24px 90px;
  overflow:hidden;
  background:
  radial-gradient(circle at 75% 40%,
  rgba(111,78,255,.14),
  transparent 38%);
}

.geo-container{
  max-width:1400px;
  margin:auto;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px;
  align-items:center;
  overflow:hidden;
}

/* LEFT */
.geo-left{
  position:relative;
  z-index:2;
  overflow-wrap:break-word;
  word-wrap:break-word;
  min-width:0;
}

/* LOGO */
.geo-logo{
  width:300px;
  height:auto;
  display:block;
}
@media(max-width:640px){
  .geo-logo{width:240px}
}

/* PILLS */
.geo-pills{
  display:flex;
  align-items:center;
  gap:14px;
  margin-top:24px;
}

.geo-pills span{
  padding:8px 18px;
  border-radius:999px;
  border:1px solid rgba(111,78,255,.16);
  background:#fff;
  color:#5F35FF;
  font-size:12px;
  font-weight:700;
  letter-spacing:.18em;
}

.geo-pills .dot{
  width:5px;
  height:5px;
  background:#b7b7c9;
  border-radius:999px;
  padding:0;
  border:none;
}

/* TITLE */
.geo-title{
  margin-top:38px;
  font-size:clamp(62px,8vw,108px);
  line-height:.92;
  letter-spacing:-0.075em;
  font-weight:900;
  color:#08091F;
}

.geo-title span{
  color:#6C3BFF;
}

/* SUBTITLE */
.geo-subtitle{
  margin-top:30px;
  font-size:clamp(22px,2.2vw,32px);
  line-height:1.22;
  letter-spacing:-0.04em;
  color:#25283A;
  max-width:780px;
}

.geo-subtitle strong{
  color:#5F35FF;
}

.geo-subtitle a{
  color:inherit;
  text-decoration:underline;
  text-underline-offset:3px;
}

.orbit-card{
  text-decoration:none;
}

/* QUOTE */
.geo-quote{
  margin-top:34px;
  display:flex;
  align-items:center;
  gap:18px;
  padding:24px;
  background:rgba(255,255,255,.74);
  border:1px solid rgba(111,78,255,.12);
  border-radius:24px;
  backdrop-filter:blur(20px);
  max-width:620px;
}

.quote-icon{
  font-size:70px;
  line-height:1;
  color:#6A46FF;
}

.geo-quote p{
  font-size:28px;
  line-height:1.18;
  letter-spacing:-0.04em;
}

/* MINI GRID */
.geo-mini-grid{
  margin-top:22px;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
  max-width:760px;
}

.mini-card{
  background:rgba(255,255,255,.82);
  border:1px solid rgba(111,78,255,.1);
  border-radius:22px;
  padding:22px 14px;
  text-align:center;
  backdrop-filter:blur(20px);
  transition:.3s ease;
}

.mini-card:hover{
  transform:translateY(-5px);
  box-shadow:0 18px 40px rgba(95,53,255,.12);
}

.mini-icon{
  color:#6A46FF;
  font-size:28px;
  margin-bottom:10px;
}

.mini-card span{
  font-size:14px;
  line-height:1.3;
  font-weight:700;
  color:#1B1B2B;
}

/* BUTTONS */
.geo-actions{
  display:flex;
  gap:18px;
  margin-top:34px;
  flex-wrap:wrap;
}

.geo-btn-primary,
.geo-btn-secondary{
  min-height:60px;
  padding:0 28px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  font-weight:800;
  font-size:16px;
  transition:.3s ease;
}

.geo-btn-primary{
  background:linear-gradient(135deg,#8B5CF6,#4F35F5);
  color:#fff;
  box-shadow:0 20px 40px rgba(79,53,245,.28);
}

.geo-btn-secondary{
  background:#fff;
  color:#161629;
  border:1px solid rgba(111,78,255,.14);
}

.geo-btn-primary:hover,
.geo-btn-secondary:hover{
  transform:translateY(-3px);
}

/* RIGHT */
.geo-right{
  position:relative;
  height:760px;
  display:flex;
  align-items:center;
  justify-content:center;
}

/* ORBIT */
.geo-orbit{
  position:relative;
  width:720px;
  height:720px;
  border-radius:999px;
}

/* CENTER */
.geo-center{
  position:absolute;
  inset:50% auto auto 50%;
  transform:translate(-50%,-50%);
  width:340px;
  height:340px;
  border-radius:999px;
  background:radial-gradient(circle,rgba(255,255,255,.98),rgba(239,232,255,.95));
  display:flex;
  align-items:center;
  justify-content:center;
  box-shadow:0 0 120px rgba(95,53,255,.24);
  overflow:hidden;
}

.geo-center-glow{
  position:absolute;
  inset:-40px;
  background:radial-gradient(circle,rgba(95,53,255,.28),transparent 70%);
}

.geo-center-logo{
  width:260px;
  position:relative;
  z-index:2;
}

/* ORBITS */
.geo-orbit::before,
.geo-orbit::after{
  content:"";
  position:absolute;
  inset:0;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.6);
}

.geo-orbit::after{
  inset:60px;
}

/* CARDS */
.orbit-card{
  position:absolute;
  width:260px;
  padding:22px;
  background:rgba(255,255,255,.88);
  backdrop-filter:blur(24px);
  border:1px solid rgba(111,78,255,.12);
  border-radius:30px;
  box-shadow:0 24px 50px rgba(95,53,255,.12);
  display:flex;
  gap:16px;
  align-items:flex-start;
}

.orbit-card img{
  width:42px;
  height:42px;
  object-fit:contain;
}

.orbit-icon{
  width:42px;
  height:42px;
  min-width:42px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:22px;
  font-weight:900;
}

.chatgpt-icon{
  background:#eafff8;
  color:#10a37f;
}

.perplexity-icon{
  background:#eef6ff;
  color:#3b82f6;
}

.google-icon{
  background:#fff4f2;
  color:#ea4335;
}

.orbit-card strong{
  display:block;
  font-size:28px;
  margin-bottom:6px;
  letter-spacing:-0.03em;
}

.orbit-card span{
  color:#43455D;
  line-height:1.45;
  font-size:15px;
}

/* CARD POSITIONS */
.card-chatgpt{
  top:10%;
  right:2%;
  transform:rotate(5deg);
}

.card-perplexity{
  left:0;
  top:46%;
  transform:rotate(-8deg);
}

.card-google{
  right:0;
  bottom:12%;
  transform:rotate(7deg);
}

/* MOBILE */
@media(max-width:980px){
  .geo-hero{
    padding:30px 18px 60px;
    overflow:hidden;
  }

  .geo-container{
    grid-template-columns:minmax(0,1fr);
    gap:40px;
  }

  .geo-right{
    height:540px;
  }

  .geo-orbit{
    transform:scale(.68);
  }

  .geo-mini-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .geo-title{
    font-size:clamp(42px,12vw,72px);
  }

  .geo-subtitle{
    font-size:16px;
    max-width:100%;
    line-height:1.4;
  }

  .geo-quote{
    padding:16px;
    gap:10px;
    max-width:100%;
  }

  .geo-quote p{
    font-size:16px;
    line-height:1.3;
  }

  .quote-icon{
    font-size:40px;
    min-width:30px;
  }

  .quote-icon{
    font-size:48px;
  }

  .geo-actions{
    flex-direction:column;
  }

  .geo-btn-primary,
  .geo-btn-secondary{
    width:100%;
  }
}

@media(max-width:420px){
  .geo-title{
    font-size:clamp(38px,11vw,54px);
  }

  .geo-mini-grid{
    gap:10px;
  }

  .mini-card{
    padding:16px 10px;
  }

  .mini-card span{
    font-size:12px;
  }

  .mini-icon{
    font-size:22px;
    margin-bottom:6px;
  }
}
</style>



<section class="ai-shift-section">
  <div class="ai-shift-container">

