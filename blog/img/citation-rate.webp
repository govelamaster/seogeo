<style>
  :root{
    --p1:#6C5CE7;
    --p2:#8E7CFF;
    --p3:#A78BFA;
    --b1:#7DD3FC;
    --b2:#93C5FD;
  }

  @font-face {
    font-family: 'Inter Fallback';
    src: local('Arial');
    size-adjust: 107%;
    ascent-override: 90%;
    descent-override: 22%;
    line-gap-override: 0%;
  }

  *{ -webkit-font-smoothing: antialiased; box-sizing: border-box; }

  html{
    scroll-behavior: smooth;
    scroll-padding-top: 24px;
    overflow-x: clip;
  }

  body{
    background: linear-gradient(180deg,#F6F4FF 0%, #EEF0FF 60%, #F4F2FF 100%);
    font-family: 'Inter', 'Inter Fallback', -apple-system, BlinkMacSystemFont, sans-serif;
    color:#0E0B25;
    overflow-x: clip;
    padding-bottom: env(safe-area-inset-bottom);
  }

  img, svg, video{ max-width: 100%; }

  .halo{
    position:absolute;
    right:-200px;
    top:-100px;
    width:900px;
    height:900px;
    background: radial-gradient(circle, rgba(139,92,246,0.18), transparent 60%);
    filter: blur(40px);
    pointer-events:none;
    z-index:0;
  }

  .glass{
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(255,255,255,0.65);
    border: 1px solid rgba(255,255,255,0.9);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.9) inset,
      0 20px 40px -20px rgba(108,92,231,0.25),
      0 8px 24px -8px rgba(108,92,231,0.10);
  }

  .pill{
    backdrop-filter: blur(20px);
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.9);
    box-shadow: 0 8px 24px rgba(108,92,231,0.10);
  }

  .btn-primary{
    background: linear-gradient(135deg,#6C5CE7 0%,#8B5CF6 100%);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.3) inset,
      0 12px 28px -8px rgba(108,92,231,0.55),
      0 4px 12px -4px rgba(108,92,231,0.4);
    transition: all .25s ease;
    letter-spacing: 0.02em;
  }
  .btn-primary:hover{
    transform: translateY(-2px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.3) inset,
      0 18px 38px -10px rgba(108,92,231,0.65);
  }

  .btn-outline{
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(15,23,42,0.12);
    box-shadow: 0 6px 16px -6px rgba(15,23,42,0.10);
    transition: all .25s ease;
    letter-spacing: 0.02em;
  }
  .btn-outline:hover{
    background:#fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -8px rgba(15,23,42,0.15);
  }

  .scribble{
    position:absolute;
    left:0;
    bottom:-18px;
    width:100%;
    max-width:340px;
    height:18px;
  }

  .bars-stage{
    position: relative;
    height: 480px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 18px;
    padding-bottom: 30px;
  }

  .bars-stage::after{
    content:'';
    position:absolute;
    left:8%;
    right:8%;
    bottom:18px;
    height:24px;
    background: radial-gradient(ellipse at center, rgba(139,92,246,0.25), transparent 70%);
    filter: blur(10px);
  }

  .bar3d{
    position: relative;
    width: 64px;
    border-radius: 6px 6px 4px 4px;
    background:
      linear-gradient(180deg,
        rgba(255,255,255,0.55) 0%,
        rgba(167,139,250,0.55) 40%,
        rgba(124,58,237,0.85) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.6),
      inset 8px 0 16px rgba(255,255,255,0.35),
      inset -8px 0 16px rgba(91,33,182,0.25),
      0 30px 50px -20px rgba(91,33,182,0.45);
    backdrop-filter: blur(8px);
  }

  .bar3d::before{
    content:'';
    position:absolute;
    top:-6px;
    left:0;
    right:0;
    height:10px;
    background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(167,139,250,0.7));
    border-radius: 8px 8px 2px 2px;
    transform: perspective(40px) rotateX(35deg);
    transform-origin: bottom;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .bar3d::after{
    content:'';
    position:absolute;
    top:0;
    right:0;
    width:14px;
    height:100%;
    background: linear-gradient(90deg, transparent, rgba(91,33,182,0.45));
    border-radius: 0 6px 4px 0;
  }

  .bar3d.b1{
    background: linear-gradient(180deg,
      rgba(255,255,255,0.55) 0%,
      rgba(147,197,253,0.55) 40%,
      rgba(96,165,250,0.85) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.6),
      inset 8px 0 16px rgba(255,255,255,0.35),
      inset -8px 0 16px rgba(37,99,235,0.25),
      0 30px 50px -20px rgba(37,99,235,0.4);
  }
  .bar3d.b2{
    background: linear-gradient(180deg,
      rgba(255,255,255,0.55) 0%,
      rgba(165,180,252,0.55) 40%,
      rgba(99,102,241,0.85) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.6),
      inset 8px 0 16px rgba(255,255,255,0.35),
      inset -8px 0 16px rgba(67,56,202,0.25),
      0 30px 50px -20px rgba(67,56,202,0.42);
  }
  .bar3d.b3{
    background: linear-gradient(180deg,
      rgba(255,255,255,0.55) 0%,
      rgba(167,139,250,0.55) 40%,
      rgba(124,58,237,0.85) 100%);
  }
  .bar3d.b4{
    background: linear-gradient(180deg,
      rgba(255,255,255,0.55) 0%,
      rgba(196,181,253,0.55) 40%,
      rgba(139,92,246,0.9) 100%);
  }
  .bar3d.b5{
    background: linear-gradient(180deg,
      rgba(255,255,255,0.6) 0%,
      rgba(216,180,254,0.6) 40%,
      rgba(168,85,247,0.92) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.6),
      inset 8px 0 16px rgba(255,255,255,0.35),
      inset -8px 0 16px rgba(126,34,206,0.3),
      0 30px 50px -20px rgba(126,34,206,0.5);
  }

  .waves{
    position:absolute;
    right:-100px;
    top:60px;
    width:900px;
    height:600px;
    pointer-events:none;
    opacity:0.55;
    z-index:0;
  }

  .logo-bar{
    width:6px;
    border-radius:2px;
    background: linear-gradient(180deg,#A78BFA,#7C3AED);
  }

  .eyebrow{
    letter-spacing: 0.22em;
  }

  h1.hero{
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-size: clamp(28px, 9vw, 64px);
    max-width: 100%;
    word-break: normal;
    overflow-wrap: break-word;
  }
  @media (max-width: 430px){
    h1.hero{ font-size: clamp(28px, 10vw, 42px); }
  }

  .grad-text{
    background: linear-gradient(135deg,#6C5CE7 0%, #8B5CF6 50%, #A78BFA 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .brand-card{
    backdrop-filter: blur(24px);
    background: rgba(255,255,255,0.72);
    border: 1px solid rgba(255,255,255,0.95);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.95) inset,
      0 24px 48px -16px rgba(108,92,231,0.22);
  }

  .ben-icon{
    background: linear-gradient(135deg,#EEEAFE,#E0DAFF);
    color:#6C5CE7;
  }

  /* Brand links */
  .brand-link{
    transition: all .2s ease;
    padding: 6px 10px;
    border-radius: 8px;
  }
  .brand-link:hover{
    background: rgba(124,58,237,0.06);
    transform: translateY(-1px);
  }
  .brand-link:hover span{
    color:#6C5CE7;
  }

  /* ===== MOBILE-FIRST GUARDRAILS (≤ 640px) ===== */
  @media (max-width: 640px){
    /* Outer hero wrapper: 20px lateral padding instead of 32px */
    .relative.max-w-7xl{ padding-left: 20px !important; padding-right: 20px !important; }

    /* Hero grid: force single column that respects parent width
       (otherwise the bars 3D push the auto column to ~410px) */
    body > div.relative.max-w-7xl > section{
      grid-template-columns: minmax(0, 1fr) !important;
      gap: 28px !important;
    }
    body > div.relative.max-w-7xl > section > div{
      min-width: 0;
      max-width: 100%;
    }

    /* Tame decorative absolute elements that could push doc width */
    .halo, .waves{ display: none; }

    /* Hero subtitle / paragraphs never overflow */
    h1.hero, h1.hero *, .hero-sub, p, h2, h3 { max-width: 100%; }

    /* Bars 3D stage shrinks gracefully */
    .bars-stage{ height: 280px; gap: 8px; padding-bottom: 18px; }
    .bar3d{ width: 38px; }
    .bar3d.b1{ height: 60px !important; }
    .bar3d.b2{ height: 110px !important; }
    .bar3d.b3{ height: 160px !important; }
    .bar3d.b4{ height: 210px !important; }
    .bar3d.b5{ height: 260px !important; }

    /* Brand card under bars: tighter padding */
    .brand-card{ padding: 14px 16px !important; }

    /* Hero CTAs: stack to full width */
    .btn-primary, .btn-outline{ width: 100%; justify-content: center; }

    /* Stat card +340%: never wider than column, and stack contents */
    .glass{ max-width: 100%; padding: 18px !important; }
    .glass > .flex{ flex-wrap: wrap; gap: 12px !important; row-gap: 8px; }
    .glass > .flex > p:first-of-type{ font-size: 36px !important; }
    .glass > .flex > p:last-of-type{ flex: 1 1 100%; font-size: 13px !important; }

    /* Scribble underline: don't push width */
    .scribble{ max-width: 100%; }

    /* Safe space at the bottom for floating WhatsApp / sticky bars */
    body{ padding-bottom: 96px; }
  }
</style>

